# datakvalitet-relay – miljø. Lastes av systemd (EnvironmentFile). Secret-or-die.
# Delt HMAC-hemmelighet for pn_auth-JWT – SAMME verdi som pn-auth/Oppdrag/Sanksjon.
AUTH_SECRET=
# Anthropic-nøkkel – KUN server-side. Aldri i nettleseren.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEBUG=false
COOKIE_NAME=pn_auth
CHAT_RATE_MAX=30
CHAT_RATE_WINDOW_S=300
