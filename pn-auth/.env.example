# pn-auth – miljø. Kopier til .env og fyll inn. Lastes av systemd (EnvironmentFile).
# Appen STOPPER hvis AUTH_SECRET/PN_AUTH_DB mangler – ingen hardkodet reserve.

# Delt HMAC-hemmelighet for pn_auth-JWT. SAMME verdi i Oppdrag og Sanksjon.
# Generer: openssl rand -hex 32
AUTH_SECRET=

# Master-database (Sanksjon sin SQLite).
PN_AUTH_DB=/opt/parknordic/parknordic.db

# false i produksjon (skrur av Swagger/CORS).
DEBUG=false

# Cookie. Domene gjør den gyldig på tvers av subpath-systemene.
COOKIE_NAME=pn_auth
COOKIE_DOMAIN=.parknordic.no
COOKIE_SECURE=true
TOKEN_TTL_MIN=60

# nginx-mount.
ROOT_PATH=/auth

# Rate-limit på /auth/login (per IP).
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW_S=900

# Kun i DEBUG: tillat portal-origin for CORS under lokal utvikling.
# DEV_CORS_ORIGIN=http://localhost:8080

# E-post til nye/nullstilte brukere – via SMTP2GO-relay (ikke direkte mot M365).
# Mangler SMTP_HOST/SMTP_USER => dry-run: meldingen skrives til EPOST_OUTBOX og
# INGENTING sendes (riktig nå, mens relayet venter på Digiflow).
PORTAL_URL=https://kontrollverktoy.parknordic.no/
# SMTP_HOST=mail.smtp2go.com
# SMTP_PORT=587
# SMTP_STARTTLS=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@parknordic.no
# Dry-run-mappe (utvikling/test); fjern når SMTP_* er satt:
# EPOST_OUTBOX=/var/lib/pn-auth/epost-outbox
